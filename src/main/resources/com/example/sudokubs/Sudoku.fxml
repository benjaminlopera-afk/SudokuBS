<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="549.0" prefWidth="759.0" stylesheets="@../../../styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.sudokubs.Controllers.SudokuController">
    <children>
        <VBox alignment="CENTER" layoutX="0.0" layoutY="0.0" prefHeight="800.0" prefWidth="1000.0" spacing="24.0">

            <Label alignment="CENTER" prefHeight="95.0" prefWidth="468.0" styleClass="title-label" text="SUDOKU 6×6">
            <font>
               <Font size="16.0" />
            </font></Label>

            <GridPane fx:id="sudokuGrid" alignment="CENTER" hgap="0" vgap="0" />

            <HBox alignment="CENTER" spacing="20.0">
                <Button fx:id="btnNuevoJuego" mnemonicParsing="false" onAction="#handleNuevoJuego" prefHeight="45.0" prefWidth="160.0" styleClass="btn-primary" text="NUEVO JUEGO" />
                <Button fx:id="btnAyuda" mnemonicParsing="false" onAction="#handleAyuda" prefHeight="45.0" prefWidth="160.0" styleClass="btn-secondary" text="AYUDA" />
            </HBox>

            <Label fx:id="lblMensaje" alignment="CENTER" prefHeight="78.0" prefWidth="648.0" styleClass="msg-label">
            <font>
               <Font size="16.0" />
            </font></Label>

        </VBox>
    </children>
</AnchorPane>
