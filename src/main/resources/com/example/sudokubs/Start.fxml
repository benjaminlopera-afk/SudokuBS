<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="549.0" prefWidth="759.0" stylesheets="@../../../styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.sudokubs.Controllers.StartController">
    <children>
        <VBox alignment="CENTER" layoutX="0.0" layoutY="0.0" prefHeight="800.0" prefWidth="1000.0" spacing="30.0">

            <Label styleClass="title-label" text="SUDOKU" />
            <Label alignment="CENTER" prefHeight="55.0" prefWidth="187.0" styleClass="subtitle-label" text="6 × 6">
            <font>
               <Font size="16.0" />
            </font></Label>
            <Label alignment="CENTER" prefHeight="70.0" prefWidth="474.0" styleClass="desc-label" text="Completa la cuadrícula sin repetir números&#10;en cada fila, columna y bloque.">
            <font>
               <Font size="14.0" />
            </font></Label>
            <Button fx:id="btnJugar" mnemonicParsing="false" onAction="#inicioJugar" prefHeight="55.0" prefWidth="200.0" styleClass="btn-primary" text="JUGAR" />
        </VBox>
    </children>
</AnchorPane>
